#!/usr/bin/env python3
"""
mrc-sessions — Session manager for Mister Claude.

Usage:
  mrc-sessions list       <mrc-dir>
  mrc-sessions pick       <mrc-dir>
  mrc-sessions name       <mrc-dir> <name> [number]
  mrc-sessions resolve    <mrc-dir> <name-or-number>
  mrc-sessions summarize  <mrc-dir> <uuid>
  mrc-sessions generate-name <mrc-dir> <uuid>
  mrc-sessions tool-misses <mrc-dir> <uuid>
"""

import curses
import json
import os
import re
import sys
import urllib.request
import urllib.error
from datetime import datetime
from pathlib import Path


def get_sessions(mrc_dir):
    """Return sessions sorted by last-updated newest-first as [(uuid, last_updated, preview), ...]."""
    sessions = []
    for f in Path(mrc_dir).glob("*.jsonl"):
        uuid = f.stem
        preview = ""
        last_ts = ""
        try:
            with open(f) as fh:
                for line in fh:
                    obj = json.loads(line)
                    ts = obj.get("timestamp", "")
                    if ts:
                        last_ts = ts
                    if not preview and obj.get("type") == "user":
                        content = obj.get("message", {}).get("content", "")
                        if isinstance(content, list):
                            content = next(
                                (c.get("text", "") for c in content if c.get("type") == "text"),
                                "",
                            )
                        preview = content[:60].replace("\n", " ")
                        if len(content) > 60:
                            preview += "..."
            if last_ts:
                sessions.append((uuid, last_ts, preview))
        except (json.JSONDecodeError, OSError):
            continue
    sessions.sort(key=lambda s: s[1], reverse=True)
    return sessions


def load_names(mrc_dir):
    """Load session-names file into a dict."""
    names_file = Path(mrc_dir) / "session-names"
    names = {}
    if names_file.exists():
        for line in names_file.read_text().splitlines():
            if "=" in line:
                uuid, name = line.split("=", 1)
                if uuid and name:
                    names[uuid] = name
    return names


def save_names(mrc_dir, names):
    """Write session-names file."""
    names_file = Path(mrc_dir) / "session-names"
    names_file.parent.mkdir(parents=True, exist_ok=True)
    names_file.write_text(
        "\n".join(f"{uuid}={name}" for uuid, name in names.items()) + "\n"
    )


def resolve(mrc_dir, query):
    """Resolve a name or list number to a UUID. Returns UUID or None."""
    sessions = get_sessions(mrc_dir)
    names = load_names(mrc_dir)

    # Try as a number
    try:
        idx = int(query)
        if 1 <= idx <= len(sessions):
            return sessions[idx - 1][0]
    except ValueError:
        pass

    # Try as a name
    for uuid, _, _ in sessions:
        if names.get(uuid) == query:
            return uuid

    # Try as a substring of a name
    for uuid, _, _ in sessions:
        name = names.get(uuid, "")
        if name and query.lower() in name.lower():
            return uuid

    # Try as a raw UUID
    for uuid, _, _ in sessions:
        if uuid == query:
            return uuid

    return None


def extract_transcript(mrc_dir, uuid, max_chars=0):
    """Extract a condensed transcript from a session JSONL, suitable for summarization.

    If max_chars > 0, stop reading once the transcript reaches that length.
    Otherwise, cap at ~16K chars (first 8K + last 8K).
    """
    jsonl_file = Path(mrc_dir) / f"{uuid}.jsonl"
    if not jsonl_file.exists():
        return ""

    lines = []
    total = 0
    with open(jsonl_file) as fh:
        for raw in fh:
            try:
                obj = json.loads(raw)
            except json.JSONDecodeError:
                continue

            msg_type = obj.get("type")
            if msg_type == "user":
                content = obj.get("message", {}).get("content", "")
                if isinstance(content, list):
                    content = " ".join(
                        c.get("text", "") for c in content if c.get("type") == "text"
                    )
                if content.strip():
                    lines.append(f"USER: {content.strip()}")
                    total += len(lines[-1])

            elif msg_type == "assistant":
                content = obj.get("message", {}).get("content", [])
                if isinstance(content, str):
                    lines.append(f"ASSISTANT: {content.strip()}")
                    total += len(lines[-1])
                elif isinstance(content, list):
                    for block in content:
                        if block.get("type") == "text" and block.get("text", "").strip():
                            lines.append(f"ASSISTANT: {block['text'].strip()}")
                            total += len(lines[-1])
                        elif block.get("type") == "tool_use":
                            name = block.get("name", "?")
                            inp = block.get("input", {})
                            # Compact tool summary
                            if name == "Bash":
                                detail = inp.get("command", "")[:80]
                            elif name in ("Grep", "Glob"):
                                detail = inp.get("pattern", "")[:80]
                            elif name in ("Read", "Write", "Edit"):
                                detail = inp.get("file_path", "")[:80]
                            else:
                                detail = str(inp)[:80]
                            lines.append(f"TOOL: {name}({detail})")
                            total += len(lines[-1])

            if max_chars > 0 and total >= max_chars:
                break

    transcript = "\n".join(lines)

    if max_chars > 0:
        return transcript[:max_chars]

    # Cap at ~16K chars: first 8K + last 8K
    if len(transcript) > 16000:
        transcript = transcript[:8000] + "\n\n[... middle truncated ...]\n\n" + transcript[-8000:]

    return transcript


def cmd_summarize(mrc_dir, uuid):
    """Generate a session summary using Claude Haiku."""
    api_key = os.environ.get("ANTHROPIC_API_KEY", "")
    if not api_key:
        return

    transcript = extract_transcript(mrc_dir, uuid)
    if not transcript:
        return

    prompt = (
        "Summarize this Claude Code session transcript concisely. Include:\n"
        "1. What was accomplished (1-2 sentences)\n"
        "2. Key files changed (bulleted list, if any)\n"
        "3. Notable decisions or tradeoffs (if any)\n\n"
        "Keep the entire summary under 5 lines. Use markdown.\n\n"
        f"Transcript:\n{transcript}"
    )

    body = json.dumps({
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": 512,
        "messages": [{"role": "user", "content": prompt}],
    }).encode()

    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=body,
        headers={
            "Content-Type": "application/json",
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
        },
    )

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read())
    except (urllib.error.URLError, OSError, json.JSONDecodeError):
        return

    text = ""
    for block in result.get("content", []):
        if block.get("type") == "text":
            text += block["text"]

    if text.strip():
        summaries_dir = Path(mrc_dir) / "session-summaries"
        summaries_dir.mkdir(parents=True, exist_ok=True)
        (summaries_dir / f"{uuid}.md").write_text(text.strip() + "\n")


def cmd_generate_name(mrc_dir, uuid):
    """Generate a descriptive kebab-case session name using Haiku."""
    # Skip if already named (manual name or previous generation)
    names = load_names(mrc_dir)
    if uuid in names:
        return

    api_key = os.environ.get("ANTHROPIC_API_KEY", "")
    if not api_key:
        print("\033[1;31m  ✦ Name generation skipped: no ANTHROPIC_API_KEY set\033[0m", file=sys.stderr)
        return

    # Use a short transcript — only need first few exchanges for a name
    transcript = extract_transcript(mrc_dir, uuid, max_chars=2000)

    prompt = (
        "Generate a short kebab-case name (3-5 words, lowercase, hyphens) that describes "
        "what this Claude Code session is about. Examples: 'android-splash-screen-hang-fix', "
        "'add-user-auth-middleware', 'refactor-db-connection-pool'.\n\n"
        "Reply with ONLY the kebab-case name, nothing else.\n\n"
        f"Transcript:\n{transcript}"
    )

    body = json.dumps({
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": 30,
        "messages": [{"role": "user", "content": prompt}],
    }).encode()

    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=body,
        headers={
            "Content-Type": "application/json",
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
        },
    )

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        error_body = e.read().decode("utf-8", errors="replace")[:200]
        print(f"\033[1;31m  ✦ Name generation failed: {e} — {error_body}\033[0m", file=sys.stderr)
        return
    except (urllib.error.URLError, OSError, json.JSONDecodeError) as e:
        print(f"\033[1;31m  ✦ Name generation failed: {e}\033[0m", file=sys.stderr)
        return

    text = ""
    for block in result.get("content", []):
        if block.get("type") == "text":
            text += block["text"]

    name = text.strip().lower().strip("\"'")
    if not name:
        print("\033[1;31m  ✦ Name generation: empty response from API\033[0m", file=sys.stderr)
        return
    if not re.match(r'^[a-z0-9]+(-[a-z0-9]+)*$', name):
        print(f"\033[1;31m  ✦ Name generation: bad format '{name}'\033[0m", file=sys.stderr)
        return

    # Re-check names in case manual name was set while we were generating
    names = load_names(mrc_dir)
    if uuid not in names:
        names[uuid] = name
        save_names(mrc_dir, names)
        print(f"\033[1;36m  ✦ Session named → \033[1;33m{name}\033[0m")


def get_summary_preview(mrc_dir, uuid):
    """Return first line of a session summary, or None."""
    summary_file = Path(mrc_dir) / "session-summaries" / f"{uuid}.md"
    if summary_file.exists():
        first_line = summary_file.read_text().split("\n", 1)[0].strip()
        # Strip markdown header prefix
        first_line = re.sub(r"^#+\s*", "", first_line)
        if first_line:
            return first_line[:60] + ("..." if len(first_line) > 60 else "")
    return None


# Patterns for tool-miss detection
TOOL_MISS_PATTERNS = [
    (re.compile(r"(\S+): command not found"), "command not found"),
    (re.compile(r"bash: (\S+): No such file or directory"), "not on PATH"),
    (re.compile(r"(?:illegal|invalid|unrecognized) option"), "option incompatibility"),
]


def cmd_tool_misses(mrc_dir, uuid):
    """Detect missing tools from a session transcript."""
    jsonl_file = Path(mrc_dir) / f"{uuid}.jsonl"
    if not jsonl_file.exists():
        return

    misses = {}  # command -> error description

    with open(jsonl_file) as fh:
        for raw in fh:
            try:
                obj = json.loads(raw)
            except json.JSONDecodeError:
                continue

            # Look at all content blocks for error patterns
            content = obj.get("message", {}).get("content", "")
            if isinstance(content, list):
                texts = [c.get("text", "") for c in content if isinstance(c, dict)]
                content = "\n".join(texts)

            for pattern, desc in TOOL_MISS_PATTERNS:
                for match in pattern.finditer(content):
                    cmd = match.group(1) if match.lastindex else match.group(0)
                    # Skip common false positives
                    if cmd in (".", "..", ""):
                        continue
                    misses[cmd] = desc

    if not misses:
        return

    # Append to log
    log_file = Path(mrc_dir) / "tool-misses.log"
    date = datetime.now().strftime("%Y-%m-%d")
    with open(log_file, "a") as f:
        for cmd, desc in misses.items():
            f.write(f"{date} session:{uuid[:8]} {cmd}: {desc}\n")

    # Print to stdout for mrc to display
    for cmd, desc in misses.items():
        print(f"{cmd}: {desc}")


def ensure_names_migrated(mrc_dir):
    """One-time migration: auto-name all unnamed sessions via Haiku API."""
    flag_file = Path(mrc_dir) / "names-migrated"
    if flag_file.exists():
        return
    sessions = get_sessions(mrc_dir)
    names = load_names(mrc_dir)
    unnamed = [(uuid, preview) for uuid, _, preview in sessions if uuid not in names]
    if unnamed:
        print(
            f"\n\033[1;36m  ✦ One-time session naming — tagging {len(unnamed)} unnamed session(s).\033[0m",
            file=sys.stderr,
        )
        print("  \033[2m  This only happens once. Future sessions are named automatically.\033[0m\n", file=sys.stderr)
        for uuid, preview in unnamed:
            label = preview if preview else uuid[:12]
            # Suppress cmd_generate_name's own stdout line — we print our own below
            _saved = sys.stdout
            sys.stdout = open(os.devnull, "w")
            try:
                cmd_generate_name(mrc_dir, uuid)
            finally:
                sys.stdout.close()
                sys.stdout = _saved
            result_name = load_names(mrc_dir).get(uuid)
            if result_name:
                print(f"\033[1;36m  ✦ \033[0;2m\"{label}\"\033[0m \033[1;36m→\033[0m \033[1;33m{result_name}\033[0m", file=sys.stderr)
            else:
                print(f"\033[1;31m  ✦ \"{label}\" → (failed)\033[0m", file=sys.stderr)
        print(file=sys.stderr)
        # Pause so the user can see results before the TUI clears the screen
        print("  \033[2mPress Enter to continue…\033[0m", file=sys.stderr, end=" ", flush=True)
        try:
            with open("/dev/tty") as tty:
                tty.readline()
        except OSError:
            pass
    flag_file.write_text(datetime.now().isoformat() + "\n")


def cmd_list(mrc_dir):
    ensure_names_migrated(mrc_dir)
    sessions = get_sessions(mrc_dir)
    if not sessions:
        print(f"No sessions found in {mrc_dir}")
        return

    names = load_names(mrc_dir)
    print(f"  {'#':<5} {'Last Used':<22} {'Name':<80} Preview")
    print(f"  {'—':<5} {'—————————':<22} {'————':<80} ———————")
    for i, (uuid, ts, preview) in enumerate(sessions, 1):
        name = names.get(uuid, "(unnamed)")
        summary = get_summary_preview(mrc_dir, uuid)
        display = summary if summary else preview
        try:
            dt = datetime.fromisoformat(ts).astimezone()
            ts_display = dt.strftime("%Y-%m-%d %H:%M:%S")
        except (ValueError, TypeError):
            ts_display = ts[:19]
        print(f"  {i:<5} {ts_display:<22} {name:<80} {display}")


def _pick_tui(stdscr, rows):
    """Curses TUI for session picking. Returns action string or None."""
    curses.curs_set(0)
    curses.use_default_colors()

    selected = 0
    scroll_offset = 0

    while True:
        stdscr.clear()
        max_y, max_x = stdscr.getmaxyx()

        # Header
        stdscr.addnstr(0, 0, "  Use the Schwartz to pick a session", max_x - 1, curses.A_BOLD)
        stdscr.addnstr(1, 0, "  \u2191/\u2193 navigate \u00b7 Enter select \u00b7 q quit", max_x - 1, curses.A_DIM)
        stdscr.addnstr(2, 0, "  " + "\u2501" * min(max_x - 4, 70), max_x - 1)

        list_start_y = 4
        visible_rows = max_y - list_start_y - 1

        if selected < scroll_offset:
            scroll_offset = selected
        elif selected >= scroll_offset + visible_rows:
            scroll_offset = selected - visible_rows + 1

        for vi in range(visible_rows):
            idx = scroll_offset + vi
            if idx >= len(rows):
                break

            action, num, ts, name, preview = rows[idx]
            indicator = "\u25b8" if idx == selected else " "

            if action == "NEW":
                line = f"  {indicator} \u2726  New session"
            else:
                name_col = name[:30]
                max_preview = max(0, max_x - 48)
                preview_col = preview[:max_preview]
                line = f"  {indicator} {num:<3} {ts:<20} {name_col:<32} {preview_col}"

            line = line[:max_x - 1]
            attr = curses.A_REVERSE if idx == selected else curses.A_NORMAL
            try:
                stdscr.addnstr(list_start_y + vi, 0, line, max_x - 1, attr)
            except curses.error:
                pass

        stdscr.refresh()

        key = stdscr.getch()
        if key in (curses.KEY_UP, ord("k")):
            selected = max(0, selected - 1)
        elif key in (curses.KEY_DOWN, ord("j")):
            selected = min(len(rows) - 1, selected + 1)
        elif key in (10, 13, curses.KEY_ENTER, curses.KEY_RIGHT):
            return rows[selected][0]
        elif key in (ord("q"), 27):
            return None
        elif key == curses.KEY_HOME:
            selected = 0
        elif key == curses.KEY_END:
            selected = len(rows) - 1
        elif key == curses.KEY_PPAGE:
            selected = max(0, selected - visible_rows)
        elif key == curses.KEY_NPAGE:
            selected = min(len(rows) - 1, selected + visible_rows)


def cmd_pick(mrc_dir):
    """Interactive session picker. Prints selected UUID or NEW to stdout."""
    ensure_names_migrated(mrc_dir)
    sessions = get_sessions(mrc_dir)
    names = load_names(mrc_dir)

    # Build rows: (action, num_display, timestamp, name, preview)
    rows = [("NEW", "", "", "New session", "")]
    for i, (uuid, ts, preview) in enumerate(sessions, 1):
        name = names.get(uuid, "(unnamed)")
        summary = get_summary_preview(mrc_dir, uuid)
        display = summary if summary else preview
        try:
            dt = datetime.fromisoformat(ts).astimezone()
            ts_display = dt.strftime("%Y-%m-%d %H:%M:%S")
        except (ValueError, TypeError):
            ts_display = ts[:19]
        rows.append((uuid, str(i), ts_display, name, display))

    # Redirect stdout to /dev/tty so curses renders to terminal
    # (stdout may be captured by bash $(...))
    saved_stdout = os.dup(1)
    tty_fd = os.open("/dev/tty", os.O_WRONLY)
    os.dup2(tty_fd, 1)
    os.close(tty_fd)

    try:
        result = curses.wrapper(_pick_tui, rows)
    finally:
        os.dup2(saved_stdout, 1)
        os.close(saved_stdout)

    if result:
        print(result)
        return 0
    return 1


def cmd_name(mrc_dir, name, target="1"):
    uuid = resolve(mrc_dir, target)
    if not uuid:
        print(f"Session not found: {target}", file=sys.stderr)
        print(f"Run 'mrc --sessions' to list available sessions.", file=sys.stderr)
        sys.exit(1)

    names = load_names(mrc_dir)
    names[uuid] = name
    save_names(mrc_dir, names)
    print(f'Named session {uuid} → "{name}"')


def cmd_resolve(mrc_dir, query):
    uuid = resolve(mrc_dir, query)
    if not uuid:
        print(f"Session not found: {query}", file=sys.stderr)
        print(f"Run 'mrc --sessions' to list available sessions.", file=sys.stderr)
        sys.exit(1)
    print(uuid)


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(1)

    cmd = sys.argv[1]
    mrc_dir = sys.argv[2]

    if cmd == "list":
        cmd_list(mrc_dir)
    elif cmd == "name":
        if len(sys.argv) < 4:
            print("Usage: mrc-sessions name <mrc-dir> <name> [number]", file=sys.stderr)
            sys.exit(1)
        target = sys.argv[4] if len(sys.argv) > 4 else "1"
        cmd_name(mrc_dir, sys.argv[3], target)
    elif cmd == "resolve":
        if len(sys.argv) < 4:
            print("Usage: mrc-sessions resolve <mrc-dir> <name-or-number>", file=sys.stderr)
            sys.exit(1)
        cmd_resolve(mrc_dir, sys.argv[3])
    elif cmd == "summarize":
        if len(sys.argv) < 4:
            print("Usage: mrc-sessions summarize <mrc-dir> <uuid>", file=sys.stderr)
            sys.exit(1)
        cmd_summarize(mrc_dir, sys.argv[3])
    elif cmd == "tool-misses":
        if len(sys.argv) < 4:
            print("Usage: mrc-sessions tool-misses <mrc-dir> <uuid>", file=sys.stderr)
            sys.exit(1)
        cmd_tool_misses(mrc_dir, sys.argv[3])
    elif cmd == "generate-name":
        if len(sys.argv) < 4:
            print("Usage: mrc-sessions generate-name <mrc-dir> <uuid>", file=sys.stderr)
            sys.exit(1)
        cmd_generate_name(mrc_dir, sys.argv[3])
    elif cmd == "pick":
        sys.exit(cmd_pick(mrc_dir))
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)
